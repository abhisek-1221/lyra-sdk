{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": false
  },
  "files": {
    "includes": [
      "packages/core/src/**/*.ts",
      "packages/core/src/**/*.tsx",
      "packages/core/tests/**/*.test.ts",
      "packages/sdk-examples/src/**/*.ts",
      "packages/sdk-examples/src/**/*.tsx",
      "packages/sdk-examples/**/*.json",
      "packages/core/**/*.json",
      "scripts/**/*.ts",
      "scripts/**/*.tsx",
      "biome.json",
      "tsconfig.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "warn",
        "noUnusedVariables": "warn"
      },
      "style": {
        "useImportType": "off",
        "noNonNullAssertion": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "semicolons": "always",
      "trailingCommas": "es5"
    }
  },
  "json": {
    "formatter": {
      "enabled": true
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
