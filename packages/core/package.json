{
  "name": "lyra-sdk",
  "version": "2.0.4",
  "description": "TypeScript SDK for YouTube workflows",
  "author": "",
  "license": "MIT",
  "homepage": "https://uselyra.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/abhisek-1221/lyra-sdk.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./url": {
      "import": {
        "types": "./dist/url.d.ts",
        "default": "./dist/url.js"
      },
      "require": {
        "types": "./dist/url.d.cts",
        "default": "./dist/url.cjs"
      }
    },
    "./fmt": {
      "import": {
        "types": "./dist/fmt.d.ts",
        "default": "./dist/fmt.js"
      },
      "require": {
        "types": "./dist/fmt.d.cts",
        "default": "./dist/fmt.cjs"
      }
    },
    "./transcript": {
      "import": {
        "types": "./dist/transcript.d.ts",
        "default": "./dist/transcript.js"
      },
      "require": {
        "types": "./dist/transcript.d.cts",
        "default": "./dist/transcript.cjs"
      }
    },
    "./ai-tools": {
      "import": {
        "types": "./dist/ai-tools.d.ts",
        "default": "./dist/ai-tools.js"
      },
      "require": {
        "types": "./dist/ai-tools.d.cts",
        "default": "./dist/ai-tools.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "keywords": [
    "youtube",
    "youtube-api",
    "youtube-data-api",
    "youtube-transcript",
    "playlist",
    "video",
    "channel",
    "comments",
    "transcript",
    "captions",
    "ai",
    "vercel-ai-sdk"
  ],
  "peerDependencies": {
    "zod": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "release": "standard-version",
    "release:dry": "standard-version --dry-run"
  },
  "devDependencies": {
    "standard-version": "^9.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
